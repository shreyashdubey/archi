# mock-app environment variables
# Copy to `.env` (or `.env.local`) and adjust. `.env*` is gitignored; this file is not.
# Both the Next dev server AND the npm scripts load these: the scripts run via
# `node --env-file-if-exists=.env --env-file-if-exists=.env.local` (see package.json),
# so the keys below take effect from the file (needs Node >= 20.18 / 22.9).

# The local mock's URL for the crawl scripts. Leave unset to AUTO-DETECT: the
# crawler probes ports 3000–3003 (where `next dev` lands when 3000 is busy) and
# uses the first that serves the mock. Set BASE_URL to force one, or set PORT.
# Used by: scripts/crawl.mjs, scripts/crawl-browser.mjs (generate-report passes it through to them)
BASE_URL=http://localhost:3000
# If you pin the dev server to a port — `PORT=3001 npm run dev` — set the SAME
# PORT here (or inline) so the crawler talks to it instead of probing.
PORT=

# Sitemap that lists every fund-detail URL (~6,000). The slug API discovers from
# this, keeping only the monitored /investments/*-growth template; the crawlers reach
# it through the slug API. Falls back to KNOWN_SLUGS if unreachable.
# Used by: packages/data (via app/api/funds/slugs)
SITEMAP_URL=https://www.bajajfinserv.in/api/amc-pdp/sitemap-details
# How long the slug API caches the sitemap in-process (ms). Default 600000 (10 min).
# Used by: app/api/funds/slugs/route.ts
SLUGS_CACHE_TTL_MS=600000

# How many RANDOM pages a local crawl / generate-report monitors. 0 = all (~6,000, like prod).
# Used by: scripts/crawl.mjs, scripts/crawl-browser.mjs, scripts/generate-report.mjs
SAMPLE_SIZE=25
# Fix the random sample for a reproducible run (any integer). Unset = new sample each run.
# Used by: scripts/crawl.mjs, scripts/crawl-browser.mjs
SAMPLE_SEED=
# Which crawler `npm run generate-report` uses: fetch (fast, default) or browser (real render times).
# Used by: scripts/generate-report.mjs
CRAWLER=fetch
# Set (to any value) to append to prior events; default (unset) clears the store each generate-report run.
# Used by: scripts/generate-report.mjs
KEEP_STORE=

# Single output folder for the report + CSV. Default: preview (tracked).
# Used by: scripts/report.mjs (and `npm run generate-report`).
REPORT_OUT_DIR=preview

# Browser-rendered crawler (scripts/crawl-browser.mjs) — real client render times.
# Renders per page (more = better percentiles). Default: 3.
CRAWL_SAMPLES=3
# Wait (ms) after load for React mount / Element Timing / SIP calc to finish. Default: 1800.
CRAWL_SETTLE_MS=1800
# Set to empty the event store before the run (clean, single-run report). Unset = append.
# (Ignored when launched via `generate-report`, which owns the clear decision via KEEP_STORE.)
RESET_STORE=
# Override the Chrome binary if not at the macOS default path.
CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Advanced browser-crawler / report knobs (sane defaults; rarely changed).
CRAWL_DEBUG_PORT=9333
CRAWL_CDP_TIMEOUT_MS=20000
# Set to any value to log Chrome DevTools Protocol traffic (scripts/crawl-browser.mjs).
CRAWL_DEBUG=
# Set to 1 to open the report in the browser from `npm run report` (same as --open).
OPEN_REPORT=
