{
  "name": "mock-app",
  "private": true,
  "version": "0.0.0",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "crawl": "node --env-file-if-exists=.env --env-file-if-exists=.env.local scripts/crawl.mjs",
    "crawl:browser": "node --env-file-if-exists=.env --env-file-if-exists=.env.local scripts/crawl-browser.mjs",
    "report": "node --env-file-if-exists=.env --env-file-if-exists=.env.local scripts/report.mjs",
    "generate-report": "node --env-file-if-exists=.env --env-file-if-exists=.env.local scripts/generate-report.mjs"
  },
  "dependencies": {
    "@mock/data": "*",
    "@mock/instrumentation": "*",
    "@mock/telemetry": "*",
    "@mock/ui": "*",
    "next": "14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "20.14.2",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "typescript": "5.4.5"
  }
}
