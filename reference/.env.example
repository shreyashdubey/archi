# reference/ environment variables (crawler worker + AWS lambdas)
# Copy to `.env` and fill in. `.env*` is gitignored; this file is not.
# Values shown are the in-code defaults; blank values are REQUIRED secrets.

# --- New Relic ---------------------------------------------------------------
# New Relic account id (REQUIRED — no default).
# Used by: crawler/playwright-crawl-worker.ts, lambda/report-shared.ts
NR_ACCOUNT_ID=
# New Relic Insert (Event API) key (REQUIRED — no default).
# Used by: crawler/playwright-crawl-worker.ts
NR_INSERT_KEY=
# NerdGraph (GraphQL) endpoint.
# Used by: lambda/report-shared.ts
NERDGRAPH_URL=https://api.newrelic.com/graphql
# New Relic Event API host (US default; EU: https://insights-collector.eu01.nr-data.net).
# Used by: crawler/playwright-crawl-worker.ts
NR_INSIGHTS_BASE_URL=https://insights-collector.newrelic.com
# NerdGraph (NRQL) resilience knobs — per-query timeout, retries, and backoff base.
# Used by: lambda/report-shared.ts
NERDGRAPH_TIMEOUT_MS=8000
NERDGRAPH_MAX_ATTEMPTS=3
NERDGRAPH_BACKOFF_MS=300

# --- AWS ---------------------------------------------------------------------
# AWS region for SES / Secrets Manager clients.
# Used by: lambda/report-shared.ts, lambda/rich-email-builder.ts
AWS_REGION=us-east-1
# Secrets Manager ARN holding New Relic credentials (REQUIRED — no default).
# Used by: lambda/report-shared.ts
SECRET_ARN=

# --- Crawler / discovery -----------------------------------------------------
# Sitemap listing every fund-detail URL (~6,000) — the authoritative page list.
# Discovery reads this (synthetics monitor + the crawl fan-out's discover step),
# extracting the slug from each /investments/{slug} entry. No hardcoded list.
# Used by: synthetics/rotating-sample-monitor.js, crawler/crawl-fanout-orchestration.md (discover step)
SITEMAP_URL=https://www.bajajfinserv.in/api/amc-pdp/sitemap-details
# Base for the monitored URL pattern: `${INVESTMENTS_BASE_URL}${slug}?next=true`
# (used to reconstruct a URL from a slug; the sitemap's absolute URL is preferred when present).
# Used by: crawler/playwright-crawl-worker.ts, synthetics/rotating-sample-monitor.js
INVESTMENTS_BASE_URL=https://www.bajajfinserv.in/investments/
# Page type label attached to crawl events.
# Used by: crawler/playwright-crawl-worker.ts
PAGE_TYPE=mf-detail
# Number of pages crawled in parallel.
# Used by: crawler/playwright-crawl-worker.ts
CONCURRENCY=4
# Event API push resilience — retries, backoff base, and per-attempt timeout for
# shipping crawl telemetry. A failed push throws so the chunk is retried (no silent loss).
# Used by: crawler/playwright-crawl-worker.ts
NR_PUSH_MAX_ATTEMPTS=4
NR_PUSH_BACKOFF_MS=250
NR_PUSH_TIMEOUT_MS=15000

# --- Digest / reporting ------------------------------------------------------
# Monitored single page path for the daily digest + incident alert.
# Used by: lambda/single-page-daily-digest.lambda.ts, lambda/incident-alert-email.lambda.ts
MONITORED_PAGE_PATH=/investments/nippon-india-taiwan-equity-fund-g-growth
# Synthetic monitor name reported on in the digest + incident alert.
# Used by: lambda/single-page-daily-digest.lambda.ts, lambda/incident-alert-email.lambda.ts
SYNTHETIC_MONITOR_NAME=investments-nippon-taiwan-growth-monitor
# NRQL reporting window (e.g. 'SINCE 1 day ago' or 'SINCE 1 week ago').
# Used by: lambda/single-page-daily-digest.lambda.ts, lambda/all-pages-daily-digest-realuser.lambda.ts, lambda/all-pages-daily-digest-crawl-charts.lambda.ts
DIGEST_PERIOD=SINCE 1 day ago
# Date suffix for the exported fleet CSV (`fleet-<REPORT_DATE>.csv`).
# Used by: lambda/all-pages-daily-digest-crawl-charts.lambda.ts
REPORT_DATE=latest
